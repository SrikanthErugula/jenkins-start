// this is skelton syntax 
 
pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                echo 'Hello, build!'
            }
        }
        stage('Test') {
            steps {
                echo "Hi, test!"
            }
        }
        stage('Deploy') {
            steps {
                echo 'Hey, Deploy!'
            }
        }
    }
}